# 这个文件负责：文档解析 + 文本分块

def chunk_text(text: str, chunk_size: int = 500, overlap: int = 50):
    """
    参数解释：
    text: 原始文本
    chunk_size: 每个分块的长度
    overlap: 块与块之间的重叠长度
    """

    chunks = []
    start = 0

    while start < len(text):
        end = start + chunk_size
        chunk = text[start:end]
        chunks.append(chunk)

        # 关键：向前推进时保留 overlap
        start += chunk_size - overlap

    return chunks